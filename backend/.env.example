# ============================================
# VARIABLES DE ENTORNO - PROYECTO C.E.R.O
# ============================================
# Copia este archivo a .env y actualiza los valores reales
# Para Vercel: agrega estas variables en Settings > Environment Variables

# ===================
# ENTORNO Y PUERTO
# ===================
NODE_ENV=production
PORT=3000

# ===================
# BASE DE DATOS (⭐ IMPORTANTE)
# ===================
# OPCIÓN 1: Usar DATABASE_URL (recomendado para Vercel)
DATABASE_URL=mysql://usuario:contraseña@host:puerto/base_de_datos

# OPCIÓN 2: Usar variables individuales (fallback si DATABASE_URL no existe)
# Estas son para Railway u otra BD MySQL
# MYSQLHOST=tramway.proxy.rlwy.net
# MYSQLPORT=56633
# MYSQLUSER=root
# MYSQLPASSWORD=tu_contraseña_aqui
# MYSQLDATABASE=railway

# ===================
# EMAIL (Resend) - Requerido para recuperación de contraseña y alertas
# ===================
# API Key de Resend (genera en https://resend.com/api-keys)
RESEND_API_KEY=re_tu_api_key_aqui

# Email verificado en Resend (debe estar confirmado en el panel de Resend)
RESEND_VERIFIED_EMAIL=tu_email@ejemplo.com

# Email donde se envían alertas de pánico
PANICO_EMAIL=autoridades@colegio.com

# ===================
# IA Y CHATBOT (Opcional)
# ===================
# API Key de Anthropic (genera en https://console.anthropic.com)
# Si no está configurada, el chatbot no funcionará (pero la app sigue funcionando)
ANTHROPIC_API_KEY=sk-ant-tu_api_key_aqui

# ===================
# URLs DEL FRONTEND
# ===================
# URL del frontend (para links en emails y redirecciones)
# En Vercel: https://tu-proyecto.vercel.app
# En local: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# URL base de API (para el cliente Vue)
# En Vercel: /api (ruta relativa)
# En local: http://localhost:3000/api
VITE_API_BASE_URL=/api
